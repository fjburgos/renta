# Example configuration file for the renta tool.
# Copy this file to renta.yaml and edit the paths for your setup.
# renta.yaml is gitignored — it will not be committed.
#
# Run with:
#   renta [path/to/renta.yaml]
#   python -m renta [path/to/renta.yaml]
# If no path is given, renta.yaml in the current directory is used.

# Base directory for resolving relative paths defined in this file.
# Can be absolute or relative to the directory where this config file lives.
# Default: "." (same directory as the config file).
base_path: data

# ---------------------------------------------------------------------------
# Capital gains from ETFs and stocks.
# Applies FIFO and wash-sale rule (2 months / 1 year).
# ---------------------------------------------------------------------------
etfs:
  # Path to the XLSX exported from DeGiro: Buzón → Transacciones → Exportar → Excel.
  # Relative paths are resolved against base_path.
  input: input/degiro/Transactions.xlsx

  # Tax year to report (e.g. 2024).
  # Set to null (or remove the line) to generate reports for all years with sales.
  year: null

  # Directory where generated reports (.txt files) will be saved.
  # Each file will be named "informe_acciones_<year>.txt".
  # Relative paths are resolved against base_path.
  output_dir: output

# ---------------------------------------------------------------------------
# Dividends (rendimientos del capital mobiliario, Art. 25.1.a LIRPF).
# Generates report with IRPF boxes and double-taxation deduction (Art. 80).
# ---------------------------------------------------------------------------
dividends:
  # Path to the XLSX exported from DeGiro: Buzón → Estado de cuenta → Exportar → Excel.
  # Different file from ETFs (Account.xlsx vs Transactions.xlsx).
  input: input/degiro/Account.xlsx

  # Tax year to report (e.g. 2024).
  # Set to null (or remove the line) to generate reports for all years with dividends.
  year: null

  # Directory where generated reports (.txt files) will be saved.
  # Each file will be named "informe_dividendos_<year>.txt".
  output_dir: output

  # Manual FX rate overrides.
  # Use when the automatic conversion (DeGiro or ECB) is not correct.
  # Each entry requires: isin, date (YYYY-MM-DD), and rate (EUR/currency).
  fx_overrides: []
  # Example:
  # fx_overrides:
  #   - isin: US0378331005
  #     date: 2024-05-17
  #     rate: "1.0897"
  #   - isin: US5949181045
  #     date: 2024-03-14
  #     rate: "1.0923"

# ---------------------------------------------------------------------------
# Revolut Flexible Account interest income (Cartera Flexible / Fondos
# Monetarios Flexibles). Generates report with rendimientos del capital
# mobiliario (Art. 25 LIRPF). Handles EUR and GBP funds automatically.
# ---------------------------------------------------------------------------
cuentas:
  # List of Revolut consolidated statement CSV files, one per tax year.
  # Export from Revolut: Profile → Documents & statements →
  # Custom statement → Excel → Tax year → Generate.
  # Files are named "consolidated-statement-v2_YYYY-MM-DD_YYYY-MM-DD_es_XXXXXX.csv".
  # Relative paths are resolved against base_path.
  input:
    - input/revolut/consolidated-statement-v2_2024-01-01_2024-12-31_es_XXXXXX.csv
    - input/revolut/consolidated-statement-v2_2025-01-01_2025-12-31_es_XXXXXX.csv

  # Tax year to report (e.g. 2025).
  # Set to null (or remove the line) to detect the year automatically from each file.
  year: null

  # Directory where the generated reports (.txt files) will be saved.
  # Each file will be named "informe_cuentas_<year>.txt".
  # Relative paths are resolved against base_path.
  output_dir: output

# ---------------------------------------------------------------------------
# Deducciones autonómicas CV (gastos personales deducibles en IRPF).
# Soporta salud, deporte, formación musical, abonos culturales, guardería
# y material escolar (Ley 13/1997, Comunitat Valenciana).
#
# Genera un informe por contribuyente con el importe bruto a introducir
# en Renta Web (la AEAT aplica porcentajes y límites automáticamente).
#
# Si declaráis por separado, usad un fichero Excel por contribuyente.
# Cada uno incluye solo los gastos que él/ella pagó.
# Los gastos se imputan al año en que se pagaron (criterio de caja),
# independientemente del periodo que cubra el servicio.
#
# Ver: docs/referencia/deducciones_autonomicas_cv_2025.md
# ---------------------------------------------------------------------------
gastos:
  # Tax year to report. Required.
  year: 2025

  # One Excel file per contributor. Each generates its own report.
  # Generate the template with:
  #   python -c "from renta.gastos.template import create_template; from pathlib import Path; create_template(Path('data/input/gastos/gastos_yo_2025.xlsx'))"
  # Relative paths are resolved against base_path.
  input:
    - input/gastos/gastos_yo_2025.xlsx
    - input/gastos/gastos_conyuge_2025.xlsx

  # Directory where generated reports (.txt files) will be saved.
  # Each file will be named "informe_gastos_<year>_<filename>.txt".
  output_dir: output
